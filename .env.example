# ═══════════════════════════════════════════════════════════════════════════
# DIVEOPS MVP — ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# DO NOT commit .env to version control.

# ── CORE ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── DATABASE ───────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/diveops

# ── SESSION & AUTH ─────────────────────────────────────────────────────────
SESSION_SECRET=your-super-secret-session-key-change-me
COOKIE_SECURE=false
BOOTSTRAP_SECRET=your-bootstrap-secret-for-initial-setup

# ── OPENAI API ─────────────────────────────────────────────────────────────
# Primary AI model for chat, transcription, and embeddings
OPENAI_API_KEY=sk-your-openai-api-key-here
# Optional: custom OpenAI-compatible endpoint (leave empty for standard OpenAI)
OPENAI_BASE_URL=

# ── ANTHROPIC API ──────────────────────────────────────────────────────────
# Claude model for risk prediction and document extraction
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ── AZURE AI SEARCH ────────────────────────────────────────────────────────
# Hybrid RAG engine for Navy Dive Manual and knowledge base
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_ADMIN_KEY=your-azure-search-admin-key
AZURE_SEARCH_QUERY_KEY=your-azure-search-query-key

# ── AZURE BLOB STORAGE ─────────────────────────────────────────────────────
# Document storage (Navy Dive Manual, uploaded files)
# Option 1: Full connection string (recommended)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=xxx;AccountKey=xxx;EndpointSuffix=core.windows.net
# Option 2: Individual credentials
AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccount
AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key
AZURE_STORAGE_CONTAINER=documents

# ── OPTIONAL SERVICES ──────────────────────────────────────────────────────
# Weather data for operations
OPENWEATHER_API_KEY=your-openweather-api-key

# Lightning distance tracking (Tomorrow.io — 500 calls/day free)
# Sign up at https://www.tomorrow.io/weather-api/ for a free API key
TOMORROW_IO_API_KEY=your-tomorrow-io-api-key

# ── PSG UNIFIED DATA LAYER ────────────────────────────────────────────────
# Central analytics database for cross-product intelligence
PSG_DATA_LAYER_URL=https://psg-data-layer.whitedune-3a34526c.centralus.azurecontainerapps.io
PSG_DATA_LAYER_API_KEY=psg_diveop_your_key_here
PSG_DATA_LAYER_ENABLED=true

# ── LOGGING ────────────────────────────────────────────────────────────────
LOG_LEVEL=info